---
const GITHUB = 'https://github.com/Shutter-Share/SproutGit';
---

<section style="
  position: relative;
  min-height: 100svh;
  display: flex;
  align-items: center;
  overflow: hidden;
  padding: 7rem 2rem 4rem;
">
  <!-- Background mesh blobs -->
  <div class="blob blob-a" style="
    width: 560px; height: 560px;
    background: color-mix(in srgb, var(--sg-primary) 18%, transparent);
    top: -120px; right: -80px;
  "></div>
  <div class="blob blob-b" style="
    width: 420px; height: 420px;
    background: color-mix(in srgb, var(--sg-accent) 12%, transparent);
    bottom: 0; left: -100px;
  "></div>
  <div class="blob blob-a" style="
    width: 280px; height: 280px;
    background: color-mix(in srgb, var(--sg-mint) 14%, transparent);
    top: 40%; right: 40%;
    animation-delay: -8s;
  "></div>

  <div style="
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    position: relative;
    z-index: 1;
  " class="hero-grid">

    <!-- Left: Copy -->
    <div data-stagger>
      <!-- Badge -->
      <div data-animate style="
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.35rem 0.85rem;
        background: color-mix(in srgb, var(--sg-primary) 12%, transparent);
        border: 1px solid color-mix(in srgb, var(--sg-primary) 30%, transparent);
        border-radius: 999px;
        font-size: 0.75rem;
        font-weight: 600;
        color: var(--sg-primary);
        letter-spacing: 0.04em;
        text-transform: uppercase;
        margin-bottom: 1.75rem;
      ">
        <span style="width:6px;height:6px;border-radius:50%;background:var(--sg-primary);display:inline-block;animation:pulse-glow 2s ease-in-out infinite;"></span>
        Early Preview
      </div>

      <!-- Headline -->
      <h1 data-animate style="
        font-size: clamp(2.6rem, 5vw, 3.8rem);
        font-weight: 700;
        line-height: 1.1;
        letter-spacing: -0.04em;
        color: var(--sg-text);
        margin: 0 0 1.25rem;
      ">
        Git built for<br>
        <span style="color: var(--sg-primary);">parallel work.</span>
      </h1>

      <!-- Sub -->
      <p data-animate style="
        font-size: 1.1rem;
        color: var(--sg-text-dim);
        line-height: 1.7;
        margin: 0 0 2.25rem;
        max-width: 480px;
      ">
        SproutGit makes worktrees first-class — so humans and AI agents
        can build in parallel without context collisions, stash juggling,
        or losing your place.
      </p>

      <!-- CTAs -->
      <div data-animate style="display: flex; gap: 0.875rem; flex-wrap: wrap; align-items: center;">
        <a href={GITHUB} target="_blank" rel="noopener noreferrer" class="btn-primary">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.342-3.369-1.342-.454-1.155-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836c.85.004 1.705.114 2.504.336 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
          </svg>
          View on GitHub
        </a>
        <a href="#features" class="btn-ghost">See features ↓</a>
      </div>

      <!-- Platform note -->
      <p data-animate style="font-size: 0.75rem; color: var(--sg-text-faint); margin: 1.5rem 0 0;">
        macOS · Linux · Windows · Open source · MIT
      </p>
    </div>

    <!-- Right: Animated commit graph -->
    <div data-animate data-graph style="
      position: relative;
      display: flex;
      justify-content: center;
      align-items: center;
    ">
      <!-- Glow backdrop -->
      <div style="
        position: absolute;
        inset: -10%;
        background: radial-gradient(ellipse at center,
          color-mix(in srgb, var(--sg-primary) 12%, transparent) 0%,
          transparent 70%);
        border-radius: 50%;
      "></div>

      <!-- Glass card holding the graph -->
      <div style="
        position: relative;
        background: color-mix(in srgb, var(--sg-surface) 70%, transparent);
        border: 1px solid var(--sg-border-subtle);
        border-radius: 16px;
        padding: 1.5rem;
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        width: 100%;
        max-width: 480px;
        box-shadow: 0 24px 64px color-mix(in srgb, #000 20%, transparent),
                    0 0 0 1px color-mix(in srgb, var(--sg-primary) 8%, transparent);
      ">
        <!-- Fake window chrome -->
        <div style="display:flex;align-items:center;gap:6px;margin-bottom:1rem;padding-bottom:0.875rem;border-bottom:1px solid var(--sg-border-subtle);">
          <span style="width:10px;height:10px;border-radius:50%;background:#f38ba8;display:inline-block;"></span>
          <span style="width:10px;height:10px;border-radius:50%;background:#f9e2af;display:inline-block;"></span>
          <span style="width:10px;height:10px;border-radius:50%;background:#a6e3a1;display:inline-block;"></span>
          <span style="margin-left:0.5rem;font-size:0.7rem;color:var(--sg-text-faint);letter-spacing:0.04em;">my-project · 3 worktrees</span>
        </div>

        <!-- SVG Commit Graph -->
        <svg viewBox="0 0 420 280" fill="none" xmlns="http://www.w3.org/2000/svg"
          aria-label="Animated commit graph showing parallel worktree branches" role="img"
          style="width:100%;display:block;">

          <!-- Lane lines -->
          <!-- Main lane (lane 0 — emerald) -->
          <path class="graph-path" d="M 30 20 L 30 260" stroke="var(--lane-0)" stroke-width="2" stroke-linecap="round"/>

          <!-- Feature branch (lane 1 — blue) splits at y=60, rejoins at y=200 -->
          <path class="graph-path" d="M 30 60 C 30 80 62 80 62 100 L 62 160 C 62 180 30 180 30 200" stroke="var(--lane-1)" stroke-width="2" stroke-linecap="round" style="animation-delay:0.3s;"/>

          <!-- Bugfix branch (lane 2 — purple) splits at y=100, open -->
          <path class="graph-path" d="M 30 100 C 30 120 94 120 94 140 L 94 220" stroke="var(--lane-2)" stroke-width="2" stroke-linecap="round" style="animation-delay:0.6s;"/>

          <!-- Agent branch (lane 3 — amber) splits at y=140 -->
          <path class="graph-path" d="M 62 140 C 62 155 126 155 126 170 L 126 240" stroke="var(--lane-3)" stroke-width="2" stroke-linecap="round" style="animation-delay:0.9s;"/>

          <!-- Commits — main lane -->
          <g class="graph-node"><circle cx="30" cy="20"  r="5" fill="var(--lane-0)" /></g>
          <g class="graph-node"><circle cx="30" cy="60"  r="5" fill="var(--lane-0)" /></g>
          <g class="graph-node"><circle cx="30" cy="100" r="5" fill="var(--lane-0)" /></g>
          <g class="graph-node"><circle cx="30" cy="140" r="5" fill="var(--lane-0)" /></g>
          <g class="graph-node"><circle cx="30" cy="200" r="5" fill="var(--lane-0)" /></g>
          <g class="graph-node"><circle cx="30" cy="240" r="6" fill="var(--lane-0)" stroke="var(--sg-bg)" stroke-width="2"/></g>

          <!-- Commits — feature lane -->
          <g class="graph-node"><circle cx="62" cy="120" r="5" fill="var(--lane-1)" /></g>
          <g class="graph-node"><circle cx="62" cy="160" r="5" fill="var(--lane-1)" /></g>

          <!-- Commits — bugfix lane -->
          <g class="graph-node"><circle cx="94" cy="160" r="5" fill="var(--lane-2)" /></g>
          <g class="graph-node"><circle cx="94" cy="220" r="5" fill="var(--lane-2)" /></g>

          <!-- Commits — agent lane -->
          <g class="graph-node"><circle cx="126" cy="188" r="5" fill="var(--lane-3)" /></g>
          <g class="graph-node"><circle cx="126" cy="240" r="5" fill="var(--lane-3)" /></g>

          <!-- Branch labels -->
          <text x="148" y="24"  font-family="var(--sg-font)" font-size="11" fill="var(--lane-0)" font-weight="600">main</text>
          <text x="148" y="64"  font-family="var(--sg-font)" font-size="10" fill="var(--lane-0)" opacity="0.7">chore: update deps</text>
          <text x="148" y="104" font-family="var(--sg-font)" font-size="10" fill="var(--lane-0)" opacity="0.7">fix: resolve merge</text>

          <text x="78"  y="124" font-family="var(--sg-font)" font-size="10" fill="var(--lane-1)">feature/auth</text>
          <text x="78"  y="164" font-family="var(--sg-font)" font-size="10" fill="var(--lane-1)" opacity="0.7">feat: add OAuth</text>

          <text x="110" y="164" font-family="var(--sg-font)" font-size="10" fill="var(--lane-2)">bugfix/nav</text>
          <text x="110" y="224" font-family="var(--sg-font)" font-size="10" fill="var(--lane-2)" opacity="0.7">fix: nav overflow</text>

          <text x="142" y="192" font-family="var(--sg-font)" font-size="10" fill="var(--lane-3)">agent/refactor</text>
          <text x="142" y="244" font-family="var(--sg-font)" font-size="10" fill="var(--lane-3)" opacity="0.7">refactor: api layer</text>

          <!-- HEAD indicator -->
          <rect x="14" y="230" width="32" height="14" rx="3" fill="color-mix(in srgb, var(--lane-0) 20%, transparent)" />
          <text x="17" y="241" font-family="var(--sg-font)" font-size="8" fill="var(--lane-0)" font-weight="700">HEAD</text>
        </svg>

        <!-- Worktree status row below graph -->
        <div style="
          display: flex;
          gap: 0.5rem;
          margin-top: 1rem;
          padding-top: 0.875rem;
          border-top: 1px solid var(--sg-border-subtle);
          flex-wrap: wrap;
        ">
          {[
            { label: 'feature/auth',    color: 'var(--lane-1)' },
            { label: 'bugfix/nav',      color: 'var(--lane-2)' },
            { label: 'agent/refactor',  color: 'var(--lane-3)' },
          ].map(wt => (
            <span style={`
              display: inline-flex; align-items: center; gap: 4px;
              padding: 2px 8px; border-radius: 999px; font-size: 10px; font-weight: 500;
              background: color-mix(in srgb, ${wt.color} 14%, transparent);
              color: ${wt.color};
              border: 1px solid color-mix(in srgb, ${wt.color} 30%, transparent);
            `}>
              <svg width="8" height="8" viewBox="0 0 8 8" fill="currentColor" aria-hidden="true"><rect width="8" height="8" rx="2"/></svg>
              {wt.label}
            </span>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @media (max-width: 768px) {
    .hero-grid {
      grid-template-columns: 1fr !important;
    }
    .hero-grid > div:last-child {
      display: none;
    }
  }
</style>
