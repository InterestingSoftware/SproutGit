---
const GITHUB = 'https://github.com/Shutter-Share/SproutGit';
---

<nav id="site-nav" style="position: fixed; top: 0; left: 0; right: 0; z-index: 50; padding: 0 2rem;">
  <div style="max-width: 1200px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; height: 64px;">
    <!-- Logo -->
    <a href="/" style="display: flex; align-items: center; gap: 0.6rem; text-decoration: none; color: var(--sg-text); font-weight: 700; font-size: 1rem; letter-spacing: -0.02em;">
      <svg width="26" height="26" viewBox="0 0 26 26" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <!-- Sprout icon -->
        <circle cx="13" cy="13" r="12" fill="color-mix(in srgb, var(--sg-primary) 15%, transparent)" />
        <path d="M13 20 L13 12" stroke="var(--sg-primary)" stroke-width="1.8" stroke-linecap="round"/>
        <path d="M13 14 C13 14 10 12 10 9 C10 9 13 8 13 12" fill="var(--sg-primary)" opacity="0.8"/>
        <path d="M13 16 C13 16 16 14 16 11 C16 11 13 10 13 14" fill="var(--sg-primary)"/>
      </svg>
      SproutGit
    </a>

    <!-- Links -->
    <div style="display: flex; align-items: center; gap: 2rem;">
      <a href="#features" style="color: var(--sg-text-dim); text-decoration: none; font-size: 0.875rem; font-weight: 500; transition: color 0.2s;"
         onmouseover="this.style.color='var(--sg-text)'" onmouseout="this.style.color='var(--sg-text-dim)'">
        Features
      </a>
      <a href="#why" style="color: var(--sg-text-dim); text-decoration: none; font-size: 0.875rem; font-weight: 500; transition: color 0.2s;"
         onmouseover="this.style.color='var(--sg-text)'" onmouseout="this.style.color='var(--sg-text-dim)'">
        Why worktrees?
      </a>
      <a href={GITHUB} target="_blank" rel="noopener noreferrer" class="btn-ghost" style="padding: 0.4rem 1rem; font-size: 0.8rem;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.342-3.369-1.342-.454-1.155-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836c.85.004 1.705.114 2.504.336 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
        </svg>
        GitHub
      </a>
    </div>
  </div>
</nav>

<style>
  @media (max-width: 600px) {
    nav > div > div { gap: 1rem; }
    a[href="#why"] { display: none; }
  }
</style>
